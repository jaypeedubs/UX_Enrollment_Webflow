# ============================================================
# ICIT Application System — Git Ignore
# ============================================================

# --- Secrets & env ---
.env
.env.*
!.env.example
# Supabase Edge Function secrets (keep the example committed)
supabase/functions/.secrets
supabase/functions/.secrets.*
!supabase/functions/.secrets.example

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# --- Build output ---
# dist/ is committed — bundle is served from GitHub Pages for Webflow
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
.vercel/
.netlify/

# --- Supabase local ---
.branches/
.temp/
supabase/.branches/
supabase/.temp/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editors / IDEs ---
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Misc ---
.cache/
coverage/
*.tsbuildinfo
docs/operations/

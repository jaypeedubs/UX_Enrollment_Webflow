# ============================================================
# Supabase Edge Function Secrets
# Set each via: supabase secrets set KEY=value
# Or bulk-set:  supabase secrets set --env-file supabase/functions/.secrets
# Never commit the real .secrets file.
# ============================================================

RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOODLE_BASE_URL=
MOODLE_API_TOKEN=
SITE_URL=

# Supabase injects these automatically in deployed functions —
# only needed for local dev via `supabase functions serve`
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
